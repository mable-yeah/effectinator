[sub_resource type="GDScript" id="GDScript_7mycd"]
script/source = "extends Button


var help_text = \"\"\"Effectinator is a project by mable d. \"yeah\"!! 

shader_type headers are not needed
screen textures will not work as intended

vertex() can be used to manipulate scale
within the image

open image -
drop image onto app

add layer name -
//layer_name = 'example'

add premade function -
//include = [function_name,other_one,also_a_func]

change canvas size, multiplicative/padding -
//canvas_size = [0.0,0.0]

change image size, in pixels -
//image_size = [0.0,0.0]

copy raw shader code - 
ctl + s

get next occurance of -
ctrl + f + highlighted text

toggle comment line -
ctrl + q + highlighted text/current line

AVAILABLE INCLUDES:
%s

open source 4 ever <3
https://github.com/mable-yeah/effectinator
\"\"\" 

func _pressed() -> void:
	var window := Popup.new()
	window.borderless = false ; window.unresizable = false
	window.size = Vector2(450,400)
	window.title = 'about effectinator / help'
	self.add_child(window)
	
	var label:CodeEdit = %code.duplicate()
	label.z_as_relative = false ; label.z_index = 0
	label.get_child(0).queue_free() ; label.set_script(null)
	label.placeholder_text = '' ; label.set_anchors_preset(Control.PRESET_FULL_RECT)
	
	label.text = help_text % ',\\n'.join(shader_utility.function_names)
	
	window.add_child(label)
	window.popup_centered()
	window.popup_hide.connect(func(): window.queue_free())
"

