script/source = "extends CodeEdit

const default_line_color = Color(\"00000000\")
const error_line_color = Color('ff786b4d')

var highlight = CodeHighlighter.new()


func _ready() -> void:
	keyword_list += shader_utility.function_names
	highlight.number_color = Color('a1ffe0')
	highlight.symbol_color = Color('abc9ff')
	highlight.function_color = Color('57b3ff')
	highlight.member_variable_color = Color('bce0ff')
	highlight.member_variable_color = Color('bce0ff')
	
	for keyword in keyword_list:
		var color:Color =  Color('ff8ccc')
		if is_special(keyword): color = Color('ffb373')
		if is_control_flow(keyword): color = Color('ff7085')
		if is_function(keyword): color = Color('a3a3f5')
		highlight.add_keyword_color(keyword,color)
	
	self.syntax_highlighter = highlight
	get_tree().process_frame.connect(refresh)

func is_hovered():
	return Rect2(Vector2(), size).has_point(get_local_mouse_position())

func refresh():
	%error_text.text = shader_loader.get_error_message()
	if shader_loader.in_error_state:
		set_error_line(shader_loader.corrected_error_line()) ; return
	set_all_lines()

func set_all_lines():
	for line_idx in get_line_count():
		set_color(line_idx,default_line_color)


func set_error_line(line_idx):
	set_all_lines()
	set_color(line_idx,error_line_color)

func set_color(line_idx:int,match_color:Color):
	line_idx = clamp(line_idx,0,get_line_count())
	var color = get_line_background_color(line_idx)
	if color == match_color:return
	set_line_background_color(line_idx,match_color)


func _gui_input(_event: InputEvent) -> void:
	if Input.is_action_just_pressed('comment'): 
		accept_event() ; comment() 
	if Input.is_action_just_pressed('ui_find_next'): 
		accept_event() ; find_next()
	if Input.is_action_just_pressed('copy_shader'):
		accept_event() ; copy_shader()

func copy_shader() -> void:
	var code = shader_loader.define_shader(text,true).get_shader().get_code()
	DisplayServer.clipboard_set(code) ; select_all()


func comment() -> void:
	if has_selection():
		var selection = get_line_ranges_from_carets()
		for caret in selection:
			for idx in range(caret.x,caret.y + 1):
				comment_line(idx)
		return
	for caret in get_sorted_carets():
		var idx = get_caret_line(caret) ; comment_line(idx)

func comment_line(idx) -> void:
	var line = get_line(idx)
	var has_comment = line.begins_with('//')
	line = line.remove_chars('//') if has_comment else '//%s' % line
	set_line(idx,line)
	set_caret_column(2 if !has_comment else 0)

func contains_mouse() -> bool:
	return Rect2(Vector2(), size).has_point(get_local_mouse_position())


#hopefully this doesnt tweak out
var last_occurrence = -1
func find_next() -> void:
	var found_lines:Array[Vector2] = []
	
	var current_line = get_caret_line() ; var selection = get_selected_text()
	var regex = RegEx.new() ; regex.compile('%s\\\\W' % selection)
	#regex is needed to make sure shit like thisvalue doesnt match with 
	#thisvalueshit (which .find does)
	
	var split = text.split('\\n', true)
	
	for index in range(split.size()):
		var this_line = split[index]
		
		var regex_search = regex.search(this_line)
		if regex_search == null:continue
		
		var this_column = this_line.find(regex_search.strings[0])
		found_lines.append(Vector2(index,this_column))
		
		if index != current_line: continue
		last_occurrence = found_lines.size() - 1
	
	if found_lines.size() == 0: return
	
	last_occurrence = (last_occurrence + 1) % found_lines.size()
	#thankyou modulo and also jane remover (she did nothing)
	
	var this_position = found_lines[last_occurrence]
	var line = this_position.x ; var column = this_position.y
	
	select(line,column,line,column + selection.length())
	center_viewport_to_caret()

func is_function(p_keyword) -> bool:
	return (shader_utility.function_names + ['fragment','vertex']).has(p_keyword)

func is_special(p_keyword:String) -> bool:
	return ['canvas_size','image_size','layer_name','include','COLOR','VERTEX','UV','TEXTURE','TEXTURE_PIXEL_SIZE'].has(p_keyword)
	
func is_control_flow(p_keyword:String) -> bool:
	return [\"break\",\"case\",\"continue\",\"default\",\"do\", \"else\",\"for\",\"if\",\"return\",\"switch\",\"while\"].has(p_keyword)

var keyword_list =  [
	'include',
	'layer_name',
	'canvas_size',
	'image_size',
	'COLOR',
	'VERTEX',
	'UV',
	'TEXTURE',
	
	\"true\",
	\"false\",

	\"void\",
	\"bool\",
	\"bvec2\",
	\"bvec3\",
	\"bvec4\",
	\"int\",
	\"ivec2\",
	\"ivec3\",
	\"ivec4\",
	\"uint\",
	\"uvec2\",
	\"uvec3\",
	\"uvec4\",
	\"float\",
	\"vec2\",
	\"vec3\",
	\"vec4\",
	\"mat2\",
	\"mat3\",
	\"mat4\",
	\"sampler2D\",
	\"isampler2D\",
	\"usampler2D\",
	\"sampler2DArray\",
	\"isampler2DArray\",
	\"usampler2DArray\",
	\"sampler3D\",
	\"isampler3D\",
	\"usampler3D\",
	\"samplerCube\",
	\"samplerCubeArray\",
	\"samplerExternalOES\",

	\"flat\",
	\"smooth\",

	\"lowp\",
	\"mediump\",
	\"highp\",

	\"uniform\",
	\"group_uniforms\",
	\"varying\",
	\"const\",
	\"struct\",
	\"shader_type\",
	\"canvas_item\",
	\"render_mode\",
	\"stencil_mode\",

	\"instance\",
	\"global\",

	\"if\",
	\"else\",
	\"for\",
	\"while\",
	\"do\",
	\"switch\",
	\"case\",
	\"default\",
	\"break\",
	\"continue\",
	\"return\",
	\"discard\",

	\"in\",
	\"out\",
	\"inout\",

	\"source_color\",
	\"color_conversion_disabled\",
	\"hint_range\",
	\"hint_enum\",
	\"instance_index\",

	\"hint_normal\",
	\"hint_default_white\",
	\"hint_default_black\",
	\"hint_default_transparent\",
	\"hint_anisotropy\",
	\"hint_roughness_r\",
	\"hint_roughness_g\",
	\"hint_roughness_b\",
	\"hint_roughness_a\",
	\"hint_roughness_normal\",
	\"hint_roughness_gray\",
	\"hint_screen_texture\",
	\"hint_normal_roughness_texture\",
	\"hint_depth_texture\",

	\"hint_blit_source0\",
	\"hint_blit_source1\",
	\"hint_blit_source2\",
	\"hint_blit_source3\",

	\"filter_nearest\",
	\"filter_linear\",
	\"filter_nearest_mipmap\",
	\"filter_linear_mipmap\",
	\"filter_nearest_mipmap_anisotropic\",
	\"filter_linear_mipmap_anisotropic\",
	\"repeat_enable\",
	\"repeat_disable\",

	\"particles\",
	\"sky\",
	\"fog\",
	\"vertex\",
	'fragment',
	'null',
	'TEXTURE_PIXEL_SIZE'
]
"

