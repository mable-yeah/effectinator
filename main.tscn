[sub_resource type="GDScript" id="GDScript_1bvp3"]
script/source = "extends ColorPickerButton

func _ready() -> void:
	picker_created.connect(
		func():
			var picker = get_picker()
			picker.can_add_swatches = false
			picker.edit_intensity = false
			picker.hex_visible = false
			picker.presets_visible = false
			picker.color_modes_visible = false
			
			picker.picker_shape = ColorPicker.SHAPE_VHS_CIRCLE
	)


func _gui_input(event: InputEvent) -> void:
	if event is InputEventMouseButton and event.button_index == 2: DisplayServer.clipboard_set(str(color))
"

